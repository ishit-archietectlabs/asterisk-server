{
  "name": "Asterisk SIP Server",
  "version": "1.0.0",
  "slug": "asterisk-sip-server",
  "description": "Asterisk PBX server with PJSIP and WebRTC support for the Customer Support System",
  "url": "https://github.com/ishit-archietectlabs/asterisk-server",
  "arch": ["amd64", "aarch64", "armv7", "i386"],
  "startup": "system",
  "boot": "auto",
  "ports": {
    "8089/tcp": 8089,
    "5060/tcp": 5060,
    "5060/udp": 5060,
    "10000-10100/udp": null
  },
  "ports_description": {
    "8089/tcp": "WebSocket (WSS) for WebRTC",
    "5060/tcp": "SIP TCP",
    "5060/udp": "SIP UDP",
    "10000-10100/udp": "RTP Media Ports"
  },
  "host_network": true,
  "options": {
    "agent_password": "changeme_agent",
    "client_default_password": "changeme_client",
    "domain": "localhost",
    "certfile": "",
    "keyfile": ""
  },
  "schema": {
    "agent_password": "str",
    "client_default_password": "str",
    "domain": "str",
    "certfile": "str",
    "keyfile": "str"
  },
  "map": ["config:rw", "ssl:ro"]
}
