{
  "name": "Asterisk SIP Server",
  "version": "1.0.1",
  "slug": "asterisk_sip_server",
  "description": "Asterisk PBX server with PJSIP and WebRTC support for the Customer Support System",
  "url": "https://github.com/ishit-archietectlabs/asterisk-server",
  "arch": [
    "amd64",
    "aarch64",
    "armv7",
    "i386"
  ],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "ingress": true,
  "ingress_port": 8090,
  "panel_icon": "mdi:phone-settings",
  "panel_title": "Asterisk Panel",
  "options": {
    "agent_password": "changeme_agent",
    "client_default_password": "changeme_client",
    "domain": "localhost",
    "certfile": "",
    "keyfile": ""
  },
  "schema": {
    "agent_password": "str",
    "client_default_password": "str",
    "domain": "str",
    "certfile": "str",
    "keyfile": "str"
  },
  "map": [
    "config:rw",
    "ssl:ro"
  ]
}
